# Ignore everything at the repository root by default.
/*

# Keep repository metadata files that define the skill catalog.
!/.gitignore
!/AGENTS.md
!/CLAUDE.md
!/LICENSE
!/README.md
!/README.zh-CN.md
!/test_all_skills.py

# Keep tracked catalog structures and their contents.
!/.agents/
!/.agents/**
!/.claude/
!/.claude/**
!/.cursor/
!/.cursor/**
!/.github/
!/.github/**
!/skills/
!/skills/**
!/tools/
!/tools/**

# Ignore editor, OS, and Python cache files anywhere, including inside allowed paths.
**/.DS_Store
**/.idea/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
